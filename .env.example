# Base de données (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (resend.com)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="ERP <onboarding@resend.dev>"

# Upstash QStash (upstash.com)
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# Upstash Redis — rate-limiter distribué (optionnel, fallback in-memory si absent)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Vercel Blob (vercel.com/storage/blob)
BLOB_READ_WRITE_TOKEN=""

# Vercel Cron — protège /api/cron/* (openssl rand -base64 32)
CRON_SECRET=""
