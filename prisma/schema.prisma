generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth.js) ───────────────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String    @unique
  emailVerified       DateTime?
  image               String?
  googleErpCalendarId String?   // id de l'agenda "ERP Freelance" dans Google Calendar
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  clients           Client[]
  projects          Project[]
  products          Product[]
  quotes            Quote[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  emailLogs         EmailLog[]
  calendarEvents      CalendarEvent[]
  calendarCategories  CalendarCategory[]
  timeEntries         TimeEntry[]
  tags              Tag[]
  profile           UserProfile?
  projectMemberships ProjectMember[]
  notifications     Notification[]
  conditionsTemplates ConditionsTemplate[]
  projectIdeas      ProjectIdea[]
  tasks             Task[]               @relation("UserTasks")
  companies          Company[]
  emitterProfiles    EmitterProfile[]
  revenues           Revenue[]
  recurringRevenues  RecurringRevenue[]
  fiscalSources      FiscalSource[]
  healthEvents        HealthEvent[]
  healthConsultations HealthConsultation[]
  healthReimbursements HealthReimbursement[]
  jobApplications     JobApplication[]
}

model ProjectIdea {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  companyName  String?
  siret        String?
  address      String?
  postalCode   String?
  city         String?
  country      String   @default("France")
  phone        String?
  website      String?
  iban         String?
  bic          String?
  quotePrefix         String   @default("DEV")
  invoicePrefix       String   @default("FAC")
  quoteNumberFormat   String   @default("PREFIX-YYYY-NNN")
  invoiceNumberFormat String   @default("PREFIX-YYYY-NNN")
  defaultConditions String?
  pdfAccentColor      String   @default("#6366f1")
  customAccentColors  String?
  logoUrl             String?
  createdAt           DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Émetteur de devis/factures. Un user peut en avoir plusieurs (« mes sociétés »),
// dont un par défaut. Porte l'identité, la banque, les CGV et le branding PDF.
// La numérotation reste globale (UserProfile.quote/invoicePrefix + formats),
// partagée entre tous les émetteurs.
model EmitterProfile {
  id                 String   @id @default(cuid())
  userId             String
  name               String   // Libellé interne pour distinguer les profils
  companyName        String? // Raison sociale
  legalForm          String? // Forme juridique (SASU, EI, micro…)
  siret              String?
  vatNumber          String?
  address            String?
  postalCode         String?
  city               String?
  country            String   @default("France")
  phone              String?
  email              String?
  website            String?
  bankName           String?  // nom de la banque (ex: Revolut) pour le bloc RÈGLEMENT
  iban               String?
  bic                String?
  defaultConditions  String?
  legalMentions      String?
  pdfAccentColor     String   @default("#6366f1")
  customAccentColors String?
  logoUrl            String?
  isDefault          Boolean  @default(false)
  fiscalSourceId     String?  // lien optionnel vers une source fiscale (ex: AE Pedro Dev)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fiscalSource FiscalSource? @relation(fields: [fiscalSourceId], references: [id], onDelete: SetNull)
  quotes       Quote[]
  invoices     Invoice[]

  @@index([userId])
  @@index([fiscalSourceId])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@unique([userId, name])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

enum ClientType {
  TO_COMPLETE
  PROSPECT
  CLIENT
  PERSONAL
  RECRUITER  // Recruteur / chasseur de tête
  SELF
  INACTIVE
}

enum CompanyType {
  CLIENT      // Client direct (facturation)
  ESN         // ESN / SSII — missions de service
  RECRUTEMENT // Cabinet de recrutement / headhunter
  PARTENAIRE  // Partenaire / sous-traitant
  FOURNISSEUR // Fournisseur de services
  AUTRE
}

enum ClientSource {
  WORD_OF_MOUTH
  LINKEDIN
  WEBSITE
  INBOUND
  OTHER
}

enum Temperature {
  COLD
  WARM
  HOT
}

enum ProspectStage {
  IDENTIFIED
  CONTACTED
  NO_RESPONSE
  REPLIED
  MEETING
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  ON_HOLD
}

enum InteractionChannel {
  EMAIL
  CALL
  LINKEDIN
  MEETING
  SMS
  OTHER
}

enum ClientFileType {
  BRIEF
  CONTRACT
  LOGO
  OTHER
}

// Une société cliente. Peut regrouper plusieurs contacts (Client). Porte les
// informations légales/de facturation (SIRET, TVA, adresse société).
model Company {
  id             String   @id @default(cuid())
  userId         String
  name           String
  siret          String?
  vatNumber      String?
  email          String?
  phone          String?
  website        String?
  address        String?
  postalCode     String?
  city           String?
  country        String?  @default("France")
  companyType    CompanyType? // catégorie de la société
  notes          String?
  fiscalSourceId String?  // source fiscale par défaut pour la facturation/les revenus
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  fiscalSource      FiscalSource?      @relation(fields: [fiscalSourceId], references: [id], onDelete: SetNull)
  contacts          Client[]
  projects          Project[]
  revenues          Revenue[]          @relation("RevenueCompany")
  recurringRevenues RecurringRevenue[] @relation("RecurringRevenueCompany")
  jobApplications   JobApplication[]

  @@unique([userId, name])
  @@index([userId])
  @@index([fiscalSourceId])
}

// Un contact. Source de vérité = firstName/lastName/label + companyId.
// `name` et `company` (string) sont des CACHES D'AFFICHAGE dénormalisés, maintenus
// à chaque écriture (cf. lib/contact.ts → computeContactName), pour éviter de
// toucher les ~40 lectures existantes (listes, dashboards…). Ne jamais écrire
// `name`/`company` directement ailleurs que via les actions CRM.
model Client {
  id            String       @id @default(cuid())
  userId        String
  type          ClientType   @default(PROSPECT)
  // Identité (source de vérité)
  firstName     String?
  lastName      String?
  label         String?
  // Cache d'affichage = label || "Prénom Nom" || société || "Sans nom"
  name          String
  // Société (relation) + cache nom dénormalisé pour l'affichage
  companyId     String?
  companyRef    Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  company       String?
  email         String?
  phone         String?
  source         ClientSource  @default(OTHER)
  temperature    Temperature   @default(COLD)
  prospectStage  ProspectStage @default(IDENTIFIED)
  priorityScore  Int           @default(1)
  notes         String?
  // Adresse du CONTACT (optionnelle — distincte de l'adresse société)
  address       String?
  postalCode    String?
  city          String?
  country       String?
  siret         String?
  linkedinUrl   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions      Interaction[]
  reminders         Reminder[]
  files             ClientFile[]
  projects          Project[]          @relation("ProjectClient")
  projectLinks      ProjectContact[]
  quotes            Quote[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  tasks             Task[]
  revenues          Revenue[]          @relation("RevenueClient")
  recurringRevenues RecurringRevenue[] @relation("RecurringRevenueClient")
  jobApplications   JobApplication[]   @relation("RecruiterApplications")

  @@index([companyId])
}

model Interaction {
  id        String             @id @default(cuid())
  clientId  String
  date      DateTime
  channel   InteractionChannel
  summary   String
  response  String?
  createdAt DateTime           @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String   @id @default(cuid())
  clientId    String
  dueDate     DateTime
  note        String?
  isDone      Boolean  @default(false)
  doneAt      DateTime?
  emailSent   Boolean  @default(false)
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientFile {
  id        String         @id @default(cuid())
  clientId  String
  name      String
  fileUrl   String
  type      ClientFileType @default(OTHER)
  createdAt DateTime       @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─── Projects ────────────────────────────────────────────────────────────────

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum MilestoneStatus {
  UPCOMING
  IN_PROGRESS
  DONE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DeliverableStatus {
  TO_DELIVER
  DELIVERED
  VALIDATED
}

enum LinkCategory {
  GITHUB
  LOCAL
  PROD
  STAGING
  DOCS
  OTHER
}

model Project {
  id             String        @id @default(cuid())
  userId         String
  // clientId reste nullable pour compatibilité facturation (Phase 2 le supprimera)
  clientId       String?
  companyId      String?
  name           String
  description    String?
  status         ProjectStatus @default(ACTIVE)
  priority       TaskPriority  @default(MEDIUM)
  startDate      DateTime?
  endDate        DateTime?
  estimatedHours Float?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  client            Client?            @relation("ProjectClient", fields: [clientId], references: [id], onDelete: SetNull)
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contactLinks      ProjectContact[]
  milestones        Milestone[]
  tasks             Task[]
  journalEntries    JournalEntry[]
  deliverables      Deliverable[]
  usefulLinks       UsefulLink[]
  postDev           PostDev?
  quotes            Quote[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  tags              Tag[]
  taskTags          TaskTag[]
  members           ProjectMember[]
  revenues          Revenue[]          @relation("RevenueProject")
  recurringRevenues RecurringRevenue[] @relation("RecurringRevenueProject")

  @@index([companyId])
}

enum ProjectMemberRole {
  ADMIN
  MEMBER
  VIEWER
}

model ProjectMember {
  id        String            @id @default(cuid())
  projectId String
  userId    String
  role      ProjectMemberRole @default(MEMBER)
  createdAt DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

// Rôle d'un contact CRM sur un projet (M2M)
enum ProjectContactRole {
  CLIENT     // Donneur d'ordre / client
  COLLEAGUE  // Collègue
  PARTNER    // Partenaire / sous-traitant
  SUPPLIER   // Fournisseur
  OTHER      // Autre
}

model ProjectContact {
  id        String             @id @default(cuid())
  projectId String
  clientId  String
  role      ProjectContactRole @default(OTHER)
  label     String?            // précision libre, ex : "Lead dev", "Chef de projet"
  createdAt DateTime           @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([projectId, clientId])
  @@index([clientId])
}

model Milestone {
  id        String          @id @default(cuid())
  projectId String
  name      String
  date      DateTime
  status    MilestoneStatus @default(UPCOMING)
  createdAt DateTime        @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]
}

model Task {
  id             String       @id @default(cuid())
  userId         String?      // propriétaire direct (null pour les tâches projet existantes)
  projectId      String?      // optionnel — tâche projet
  clientId       String?      // optionnel — tâche client directe
  milestoneId    String?
  parentTaskId   String?
  title          String
  description    String?
  status         TaskStatus   @default(TODO)
  priority       TaskPriority @default(LOW)
  importance     Int          @default(1)
  isGroup        Boolean      @default(false)
  color          String?
  order          Int          @default(0)
  estimatedHours Float?
  startedAt      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user        User?        @relation("UserTasks", fields: [userId], references: [id], onDelete: SetNull)
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  milestone   Milestone?   @relation(fields: [milestoneId], references: [id])
  parentTask  Task?        @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks    Task[]       @relation("SubTasks")
  timeEntries TimeEntry[]
  taskTags    TaskTag[]    @relation("TaskToTaskTag")
}

model TaskTag {
  id        String   @id @default(cuid())
  projectId String
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]  @relation("TaskToTaskTag")

  @@unique([projectId, name])
}

model TimeEntry {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  startedAt DateTime
  endedAt   DateTime?
  duration  Int?
  note      String?
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JournalEntry {
  id        String   @id @default(cuid())
  projectId String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Deliverable {
  id        String            @id @default(cuid())
  projectId String
  name      String
  status    DeliverableStatus @default(TO_DELIVER)
  dueDate   DateTime?
  createdAt DateTime          @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model UsefulLink {
  id        String       @id @default(cuid())
  projectId String
  label     String
  url       String
  category  LinkCategory @default(OTHER)
  createdAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Post-Dev ─────────────────────────────────────────────────────────────────

enum RenewalType {
  DOMAIN
  HOSTING
  OTHER
}

model PostDev {
  id           String   @id @default(cuid())
  projectId    String   @unique
  prodUrl      String?
  adminUrl     String?
  hostingUrl   String?
  registrarUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  renewals        Renewal[]
  monitoringChecks MonitoringCheck[]
}

model Renewal {
  id              String      @id @default(cuid())
  postDevId       String
  type            RenewalType @default(OTHER)
  name            String
  amount          Float?
  purchasedAt     DateTime?
  periodMonths    Int?
  expiresAt       DateTime
  reminderSent30  Boolean     @default(false)
  reminderSent7   Boolean     @default(false)
  createdAt       DateTime    @default(now())

  postDev PostDev @relation(fields: [postDevId], references: [id], onDelete: Cascade)
}

model MonitoringCheck {
  id             String   @id @default(cuid())
  postDevId      String
  checkedAt      DateTime @default(now())
  isUp           Boolean
  statusCode     Int?
  responseTimeMs Int?

  postDev PostDev @relation(fields: [postDevId], references: [id], onDelete: Cascade)
}

// ─── Facturation ─────────────────────────────────────────────────────────────

enum ProductUnit {
  HOUR
  DAY
  MONTH
  YEAR
  UNIT
  FLAT
}

enum BillingType {
  ONE_SHOT
  MONTHLY
  QUARTERLY
  YEARLY
}

enum QuoteStatus {
  DRAFT
  VALIDATED
  SENT
  WAITING_DEPOSIT
  DEPOSIT_RECEIVED
  ACCEPTED
  IN_PROGRESS
  SIGNED
  REJECTED
}

enum InvoiceType {
  DEPOSIT
  FINAL
  RECURRING
  STANDALONE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  SENT
  PAID
  LATE
  CANCELLED
}

enum RecurringFrequency {
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum EmailLogStatus {
  SENT
  DELIVERED
  OPENED
  BOUNCED
}

model Product {
  id             String      @id @default(cuid())
  userId         String
  name           String
  description    String?
  unitPrice      Float
  unit           ProductUnit @default(UNIT)
  billingType    BillingType @default(ONE_SHOT)
  defaultTaxRate Float       @default(0)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  quoteLines  QuoteLine[]
  invoiceLines InvoiceLine[]
}

model Quote {
  id                String      @id @default(cuid())
  userId            String
  clientId          String
  projectId         String?
  emitterProfileId  String?
  number            String
  status            QuoteStatus @default(DRAFT)
  depositPercent    Float       @default(0)
  totalHT           Float       @default(0)
  notes             String?
  generalConditions String?
  expiresAt         DateTime?
  validatedAt       DateTime?
  sentAt            DateTime?
  acceptedAt        DateTime?
  signedFileUrl     String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client          @relation(fields: [clientId], references: [id])
  project  Project?        @relation(fields: [projectId], references: [id])
  emitter  EmitterProfile? @relation(fields: [emitterProfileId], references: [id], onDelete: SetNull)
  lines    QuoteLine[]
  invoices Invoice[]
}

model QuoteLine {
  id          String      @id @default(cuid())
  quoteId     String
  productId   String?
  description String
  detail      String?
  quantity    Float       @default(1)
  unitPrice   Float
  taxRate     Float       @default(0)
  billingType BillingType @default(ONE_SHOT)
  total       Float

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model Invoice {
  id               String        @id @default(cuid())
  userId           String
  clientId         String
  projectId        String?
  quoteId          String?
  emitterProfileId String?
  number           String
  type             InvoiceType   @default(STANDALONE)
  status           InvoiceStatus @default(DRAFT)
  totalHT          Float         @default(0)
  depositDeducted  Float         @default(0)
  dueDate          DateTime?
  paidAt           DateTime?
  sentAt           DateTime?
  issuedAt         DateTime?
  cancelledAt       DateTime?
  pdfUrl            String?
  notes             String?
  generalConditions String?
  createdAt         DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client          @relation(fields: [clientId], references: [id])
  project   Project?        @relation(fields: [projectId], references: [id])
  quote     Quote?          @relation(fields: [quoteId], references: [id])
  emitter   EmitterProfile? @relation(fields: [emitterProfileId], references: [id], onDelete: SetNull)
  lines     InvoiceLine[]
  emailLogs EmailLog[]
  payments  Payment[]
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Float
  paidAt    DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model InvoiceLine {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  description String
  detail      String?
  quantity    Float    @default(1)
  unitPrice   Float
  taxRate     Float    @default(0)
  total       Float

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model RecurringInvoice {
  id                   String             @id @default(cuid())
  userId               String
  clientId             String
  projectId            String?
  name                 String
  frequency            RecurringFrequency @default(MONTHLY)
  nextGenerationDate   DateTime
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client   @relation(fields: [clientId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
}

model EmailLog {
  id              String         @id @default(cuid())
  userId          String
  invoiceId       String?
  to              String
  subject         String
  resendMessageId String?
  status          EmailLogStatus @default(SENT)
  sentAt          DateTime       @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id])
}

// ─── Calendar ─────────────────────────────────────────────────────────────────

enum CalendarSourceType {
  MANUAL
  INVOICE
  TASK
  MILESTONE
  INTERACTION
  RENEWAL
  REMINDER
  GOOGLE
}

model CalendarEvent {
  id             String             @id @default(cuid())
  userId         String
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  allDay         Boolean            @default(false)
  sourceType     CalendarSourceType @default(MANUAL)
  sourceId       String?            // id Google pour sourceType=GOOGLE ; id JournalEntry pour sourceType=MANUAL+note
  categoryId     String?
  projectId      String?            // lien optionnel vers un projet
  clientId       String?            // lien optionnel vers un contact
  googleEventId  String?            // id de l'événement côté Google (pour les MANUAL poussés)
  googleSyncedAt DateTime?          // dernière synchro confirmée vers Google
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category CalendarCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model CalendarCategory {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   // hex couleur, ex: "#6366f1"
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events CalendarEvent[]

  @@unique([userId, name])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  href      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ConditionsTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  content   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Sources fiscales ────────────────────────────────────────────────────────

// Catégorie fiscale d'une source de revenus.
enum FiscalBucket {
  AE_URSSAF     // CA auto-entrepreneur déclaré à l'URSSAF
  NON_IMPOSABLE // Revenus non imposables (études, baby-sitting, chèques cadeaux…)
  OTHER         // Autres (salaires CDD/CDI, investissements…)
}

// Regroupe des revenus sous un même libellé fiscal personnalisé.
// Pour l'AE : lié à un EmitterProfile (Pedro Dev → SIRET, dénomination…).
// Pour les autres : source autonome avec saisie manuelle dans le module Revenus.
model FiscalSource {
  id        String       @id @default(cuid())
  userId    String
  name      String       // "Pedro Dev AE", "Baby-sitting", "Bourse INSA"
  bucket    FiscalBucket
  color     String       @default("#6366f1")
  isActive  Boolean      @default(true)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  emitterProfiles   EmitterProfile[]
  revenues          Revenue[]
  recurringRevenues RecurringRevenue[]
  companies         Company[]

  @@index([userId])
}

// ─── Revenus hors auto-entreprise ────────────────────────────────────────────

enum RevenueType {
  SALARY      // Salaire (CDI, CDD, intérim)
  FREELANCE   // Mission AE (Auto-Entrepreneur)
  STUDY       // Étude / mission rémunérée hors AE
  INVESTMENT  // Investissements (dividendes, intérêts, PEA)
  RENTAL      // Revenus locatifs
  PLATFORM    // Plateformes (YouTube, Twitch, Patreon…)
  OTHER       // Autre
}

enum RevenueStatus {
  PENDING   // En attente de réception
  RECEIVED  // Reçu
}

model Revenue {
  id                 String        @id @default(cuid())
  userId             String
  type               RevenueType
  label              String        // ex: "Salaire mai 2026", "Loyer T2 Paris"
  amount             Float
  currency           String        @default("EUR")
  status             RevenueStatus @default(PENDING)
  receivedAt         DateTime?     // date de réception effective
  expectedAt         DateTime?     // date prévisionnelle de réception (revenus en attente)
  paymentMethod      String?       // VIREMENT, ESPECES, CHEQUE, CARTE, PAYPAL, OTHER
  notes              String?
  period             String?       // "2026-06" — pour regroupement mensuel
  recurringRevenueId String?       // lien vers le modèle récurrent parent
  fiscalSourceId     String?       // lien vers la source fiscale (baby-sitting, études…)
  companyId          String?
  clientId           String?
  projectId          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  recurringRevenue RecurringRevenue? @relation(fields: [recurringRevenueId], references: [id], onDelete: SetNull)
  fiscalSource     FiscalSource?     @relation(fields: [fiscalSourceId], references: [id], onDelete: SetNull)
  company          Company?          @relation("RevenueCompany", fields: [companyId], references: [id], onDelete: SetNull)
  client           Client?           @relation("RevenueClient", fields: [clientId], references: [id], onDelete: SetNull)
  project          Project?          @relation("RevenueProject", fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([recurringRevenueId])
  @@index([fiscalSourceId])
  @@index([companyId])
  @@index([clientId])
  @@index([projectId])
}

model RecurringRevenue {
  id            String      @id @default(cuid())
  userId        String
  type          RevenueType
  label         String
  amount        Float
  currency      String      @default("EUR")
  dayOfMonth    Int         @default(1)   // jour du mois attendu (1–28)
  paymentMethod String?
  notes         String?
  isActive      Boolean     @default(true)
  fiscalSourceId String?    // lien vers la source fiscale
  companyId     String?
  clientId      String?
  projectId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fiscalSource FiscalSource? @relation(fields: [fiscalSourceId], references: [id], onDelete: SetNull)
  revenues     Revenue[]
  company      Company?      @relation("RecurringRevenueCompany", fields: [companyId], references: [id], onDelete: SetNull)
  client       Client?       @relation("RecurringRevenueClient", fields: [clientId], references: [id], onDelete: SetNull)
  project      Project?      @relation("RecurringRevenueProject", fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([fiscalSourceId])
  @@index([companyId])
  @@index([clientId])
  @@index([projectId])
}

// ─── Santé ────────────────────────────────────────────────────────────────────

enum HealthEventType {
  INJURY   // Blessure 🩸
  ILLNESS  // Maladie 🩸
  OTHER
}

enum PractitionerType {
  GENERAL       // Médecin généraliste
  OSTEOPATH     // Ostéopathe
  SPECIALIST    // Spécialiste
  SOS_MEDECIN   // SOS Médecin / Urgences
  NURSE         // Infirmier(ère)
  PHYSIO        // Kinésithérapeute
  DENTIST       // Dentiste
  OTHER
}

enum ReimbursementSource {
  SECU
  MUTUELLE
}

enum ReimbursementStatus {
  PENDING   // En attente de réception
  RECEIVED  // Reçu
}

// Blessure ou maladie 🩸
model HealthEvent {
  id          String          @id @default(cuid())
  userId      String
  date        DateTime
  type        HealthEventType
  title       String
  description String?
  bodyPart    String?         // localisation libre (dos, genou, coude…)
  resolvedAt  DateTime?       // date de guérison / résolution

  consultations HealthConsultation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Consultation médicale 🥼
model HealthConsultation {
  id               String           @id @default(cuid())
  userId           String
  date             DateTime
  practitionerName String
  practitionerType PractitionerType @default(OTHER)
  title            String           // motif / résumé
  notes            String?
  cost             Float?           // montant payé (ex. 63)
  hasDocument      Boolean          @default(false)
  documentRef      String?          // URL ou chemin Drive

  healthEventId String?
  healthEvent   HealthEvent? @relation(fields: [healthEventId], references: [id], onDelete: SetNull)

  reimbursements HealthReimbursement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([healthEventId])
}

// Remboursement 💸 — modèle PENDING/RECEIVED (cf. Revenue) pour suivre les
// montants attendus vs réellement reçus, par source (sécu / mutuelle).
model HealthReimbursement {
  id           String              @id @default(cuid())
  userId       String
  amount       Float
  source       ReimbursementSource
  status       ReimbursementStatus @default(PENDING)
  expectedDate DateTime?           // date prévisionnelle de réception
  receivedAt   DateTime?           // date de réception effective (si RECEIVED)
  notes        String?

  consultationId String?
  consultation   HealthConsultation? @relation(fields: [consultationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consultationId])
}

// ─── Entretiens / Recrutement ─────────────────────────────────────────────────

// Étapes du processus de candidature/recrutement.
enum JobApplicationStatus {
  WISHLIST    // Repéré, à postuler
  APPLIED     // Candidature envoyée
  SCREENING   // Pré-qualification (call RH)
  INTERVIEW   // Entretien
  TECHNICAL   // Test / entretien technique
  FINAL       // Entretien final / décisionnel
  OFFER       // Offre reçue
  ACCEPTED    // Offre acceptée 🎉
  REJECTED    // Refusé
  WITHDRAWN   // Désistement de ma part
  GHOSTED     // Sans réponse / ghosté
}

enum JobEventType {
  APPLICATION    // Candidature envoyée
  CALL           // Appel téléphonique
  VIDEO          // Visio
  ONSITE         // Entretien sur site
  EMAIL          // Email
  MESSAGE        // Message (LinkedIn, SMS…)
  TECHNICAL_TEST // Test technique
  OFFER          // Offre / proposition
  OTHER
}

// Une candidature / un processus de recrutement suivi.
model JobApplication {
  id          String               @id @default(cuid())
  userId      String
  companyName String                              // nom société (cache d'affichage / saisie rapide)
  companyId   String?                             // lien optionnel vers une Company existante
  position    String                              // poste visé
  location    String?                             // ville / adresse
  workMode    String?                             // remote / hybride / présentiel (libre)
  status      JobApplicationStatus @default(WISHLIST)
  source      String?                             // LinkedIn, cooptation, spontanée…
  url         String?                             // lien de l'offre
  salaryMin   Float?
  salaryMax   Float?
  salaryNote  String?                             // précisions (variable, package…)
  notes       String?
  priority    Int                  @default(1)    // tri / mise en avant
  contactId   String?                             // recruteur (contact CRM)
  appliedAt   DateTime?                           // date de candidature
  nextActionAt    DateTime?                        // prochain point / RDV
  nextActionLabel String?                          // libellé du prochain point
  closedAt    DateTime?                           // date de clôture (accepté/refusé/désisté)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact Client?               @relation("RecruiterApplications", fields: [contactId], references: [id], onDelete: SetNull)
  events  JobApplicationEvent[]

  @@index([userId])
  @@index([companyId])
  @@index([contactId])
}

// Un point de contact / événement dans un processus de candidature.
model JobApplicationEvent {
  id            String       @id @default(cuid())
  userId        String
  applicationId String
  date          DateTime
  type          JobEventType @default(OTHER)
  title         String
  notes         String?
  outcome       String?       // compte rendu post-entretien
  cancelledAt   DateTime?     // annulation de l'événement

  createdAt DateTime @default(now())

  application JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([applicationId])
}
